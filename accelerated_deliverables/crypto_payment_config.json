  "payment_settings": {
    "default_currency": "USD",
    "supported_fiat_currencies": ["USD", "EUR", "GBP", "JPY", "CNY"],
    "payment_expiry_hours": 24,
    "auto_refund_hours": 168,
    "minimum_payment_usd": 1,
    "maximum_payment_usd": 10000,
    "qr_code_size": "300x300",
    "qr_code_provider": "https://api.qrserver.com/v1/create-qr-code/"
  },
  
  "webhook_settings": {
    "enabled": true,
    "secret_header": "X-Payment-Signature",
    "events": [
      "payment.created",
      "payment.confirmed",
      "payment.completed",
      "payment.expired",
      "payment.failed",
      "payment.refunded"
    ],
    "retry_policy": {
      "max_attempts": 5,
      "initial_delay_seconds": 1,
      "max_delay_seconds": 60,
      "backoff_factor": 2
    }
  },
  
  "security_settings": {
    "signature_algorithm": "HMAC-SHA256",
    "jwt_expiry_hours": 24,
    "ip_whitelist": [],
    "rate_limit": {
      "requests_per_minute": 60,
      "burst_limit": 100
    },
    "ssl_required": true,
    "two_factor_auth": false
  },
  
  "notification_settings": {
    "email_notifications": {
      "enabled": true,
      "provider": "smtp",
      "templates": {
        "payment_created": "payment_created.html",
        "payment_confirmed": "payment_confirmed.html",
        "payment_completed": "payment_completed.html"
      }
    },
    "sms_notifications": {
      "enabled": false,
      "provider": "twilio"
    },
    "push_notifications": {
      "enabled": true,
      "provider": "firebase"
    }
  },
  
  "database_settings": {
    "type": "postgresql",
    "host": "localhost",
    "port": 5432,
    "database": "crypto_payments",
    "username": "payment_user",
    "password_env_var": "DB_PASSWORD",
    "connection_pool": {
      "min_connections": 5,
      "max_connections": 20,
      "max_lifetime_seconds": 3600
    },
    "backup": {
      "enabled": true,
      "frequency": "daily",
      "retention_days": 30
    }
  },
  
  "monitoring_settings": {
    "health_check_endpoint": "/health",
    "metrics_endpoint": "/metrics",
    "log_level": "INFO",
    "log_retention_days": 90,
    "alerting": {
      "enabled": true,
      "providers": ["slack", "email"],
      "thresholds": {
        "error_rate_percent": 1,
        "response_time_ms": 1000,
        "payment_failure_rate": 5
      }
